.env
.env.*
!.env.example

# Editor
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo
*~
.DS_Store

# Build
dist
build
out

# Logs
logs
*.log

# Python
__pycache__/
*.py[cod]
venv/
scripts/raw_data/

# Temporary
*.tmp
uploads/
temp/

# Raw data files (large CSV/Excel, imported via scripts)
stores/*
# …except Pinia store source files (Nuxt auto-imports stores/*.ts)
!stores/*.ts

# 龐君華會督文集典藏：原 nonchurch-nuxt 轉運資料夾（已搬入 pages/, layouts/, server/api/, stores/, scripts/）
/pong-archive/

# Sermon transcript working area — outputs shipped via skill, not source-tracked
/tmp_sermon/

# Local scheduler / new-book staging inside skill folders (binaries, lock files)
/.claude/scheduled_tasks.lock
/.claude/skills/*/new-book/
# Temp working directories (sermon audio downloads, FHL article scrape, methodist paper PDFs)
/_tmp_audio/
/tmp_fhl/
/tmp_methodist/
/tmp_cmpc/
/tmp_talk/

# Local-only source material (z-library downloads, 龐牧師事工報告原稿已匯入)
/z-lib/
/龐君華牧師歷年事工報告/

# Photo library index — local file, regenerated by scripts/build_photo_index.py
/scripts/photo_index.json
# Rename / classify run output (regenerated per run)
/scripts/photo_rename_report*.json
/scripts/photo_rename_log.jsonl
/scripts/photo_classification_report.json
/scripts/photo_move_log.jsonl
/scripts/photo_rollback_log.jsonl
# One-off scripts for batch imports (kept local, not source-tracked)
/scripts/_*.py
# One-off node helpers / local verification harnesses (e.g. Playwright UI checks)
/scripts/_*.mjs
# One-off data snapshots / indexes regenerated by crawlers
/scripts/_*.json
# Per-script output directories (e.g. scripts/_denzinger_toc/dh_titles.json)
/scripts/_*/
# Per-script `.bak` snapshots (e.g. data/creeds/.../*-chinese.txt.bak)
# git history already preserves the prior version; the bak is redundant.
*.bak
.claude/skills/ebook-collected-works/mueller_data/_queue.lock

